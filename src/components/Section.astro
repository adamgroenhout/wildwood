---
interface Props {
  theme?: 'sage' | 'cream' | 'sand' | 'paper' | 'charcoal' | 'olive' | 'alternate' | 'terracotta' | 'none';
  padding?: 'standard' | 'large' | 'small' | 'hero' | 'none';
  class?: string;
  id?: string;
}

const { 
  theme = 'none', 
  padding = 'standard', 
  class: className = '',
  id 
} = Astro.props;

const themeClasses = {
  sage: 'bg-sage',
  cream: 'bg-cream',
  sand: 'bg-sand',
  paper: 'bg-paper',
  charcoal: 'bg-charcoal',
  olive: 'bg-olive',
  terracotta: 'bg-terracotta',
  alternate: 'bg-alternate',
  none: '',
};

const paddingClasses = {
  standard: 'py-[var(--spacing-section-standard-y)] md:py-[var(--spacing-section-standard-y-md)] px-4',
  large: 'py-[var(--spacing-section-large-y)] md:py-[var(--spacing-section-large-y-md)] px-4',
  small: 'py-[var(--spacing-section-small-y)] md:py-[var(--spacing-section-small-y-md)] px-4',
  hero: 'pt-[var(--spacing-hero-pt)] md:pt-[var(--spacing-hero-pt-md)] pb-[var(--spacing-hero-pb)] md:pb-[var(--spacing-hero-pb-md)] px-4',
  'top-only': 'pt-[var(--spacing-section-standard-y)] md:pt-[var(--spacing-section-standard-y-md)] pb-0 px-4',
  none: '',
};
---

<section 
  id={id}
  class:list={[
    themeClasses[theme], 
    paddingClasses[padding],
    className
  ]}
>
  <slot />
</section>
