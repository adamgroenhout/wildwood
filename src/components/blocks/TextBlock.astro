---
import Section from '../Section.astro';
import Button from '../Button.astro';
import { marked } from 'marked';

interface Props {
  data: {
    title?: string;
    subtitle?: string;
    body: string;
    button_text?: string;
    button_url?: string;
    theme?: 'sage' | 'cream' | 'sand' | 'paper' | 'charcoal' | 'olive' | 'alternate';
    alignment?: 'left' | 'center';
    padding?: 'standard' | 'large' | 'small' | 'top-only' | 'bottom-only' | 'x-only' | 'none';
  }
}

const { data } = Astro.props;
const isDark = ['charcoal', 'olive', 'terracotta'].includes(data.theme || '');
const alignment = data.alignment || 'left';
const isCentered = alignment === 'center';
---

<Section theme={data.theme || 'alternate'} padding={data.padding || 'standard'} class={isDark ? 'theme-dark' : ''}>
  <div class:list={["max-w-4xl mx-auto space-y-8", isCentered ? 'text-center' : 'text-left']}>
    {(data.title || data.subtitle) && (
      <div class:list={["space-y-4", isCentered ? 'text-center max-w-3xl mx-auto' : 'text-left']}>
        {data.subtitle && (
          <p class="eyebrow text-terracotta text-pretty">
            {data.subtitle}
          </p>
        )}
        {data.title && (
          <h2 class="h2-serif leading-tight whitespace-pre-wrap text-pretty">{data.title.split('\n').map((line, i) => (
              <Fragment key={i}>
                {i > 0 && <br />}
                {line}
              </Fragment>
            ))}</h2>
        )}
      </div>
    )}
    
    {data.body && (
      <div class:list={[
        "body-lg opacity-85 prose text-pretty text-left",
        isCentered ? 'max-w-3xl mx-auto' : '',
        !data.title && data.subtitle ? 'mt-4' : ''
      ]} set:html={marked.parse(data.body)} />
    )}

    {data.button_text && data.button_url && (
      <div class:list={[
        "pt-8",
        isCentered ? 'text-center' : 'text-left'
      ]}>
        <Button href={data.button_url} theme={isDark ? 'white' : 'terracotta'}>
          {data.button_text}
        </Button>
      </div>
    )}
  </div>
</Section>
