---
import Section from '../Section.astro';
import { marked } from 'marked';

interface Props {
  data: {
    title?: string;
    subtitle?: string;
    body: string;
    theme?: 'sage' | 'cream' | 'sand' | 'paper' | 'charcoal' | 'olive' | 'alternate';
    alignment?: 'left' | 'center';
    padding?: 'standard' | 'large' | 'small' | 'none';
  }
}

const { data } = Astro.props;
const alignmentClass = data.alignment === 'center' ? 'text-center mx-auto' : 'text-left';
---

<Section theme={data.theme || 'alternate'} padding={data.padding || 'standard'}>
  <div class={`max-w-4xl ${alignmentClass}`}>
    {data.title && (
      <h2 class={`h1-serif mb-6 text-balance ${data.alignment === 'center' ? 'mx-auto' : ''}`}>{data.title}</h2>
    )}
    {data.subtitle && (
      <p class={`subtitle-serif mb-10 opacity-90 ${data.alignment === 'center' ? 'mx-auto' : ''}`}>{data.subtitle}</p>
    )}
    {data.body && (
      <div class={`body-lg opacity-90 prose ${data.alignment === 'center' ? 'mx-auto text-left' : ''}`} set:html={marked.parse(data.body)} />
    )}
  </div>
</Section>
