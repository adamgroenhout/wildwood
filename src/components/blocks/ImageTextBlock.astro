---
import Section from '../Section.astro';
import { formatUrl } from '../../utils/paths';
import { Image } from 'astro:assets';
import { marked } from 'marked';

interface Props {
  data: {
    title?: string;
    subtitle?: string;
    body: string;
    image: string;
    image_alt?: string;
    image_position?: 'left' | 'right';
    link_text?: string;
    link_url?: string;
    theme?: 'sage' | 'cream' | 'sand' | 'paper' | 'charcoal' | 'olive' | 'alternate';
    padding?: 'standard' | 'large' | 'small' | 'none';
  }
}

const { data } = Astro.props;
const flexDirection = data.image_position === 'right' ? 'md:flex-row-reverse' : 'md:flex-row';
---

<Section theme={data.theme || 'alternate'} padding={data.padding || 'small'} class="overflow-hidden">
  <div class={`max-w-7xl mx-auto flex flex-col items-center gap-12 lg:gap-16 ${flexDirection}`}>
    <div class="w-full md:w-1/2 group">
      {data.image && (
        <Image
          src={formatUrl(data.image)}
          alt={data.image_alt || ''}
          width={800}
          height={1000}
          class="w-full h-auto max-h-[600px] object-cover rounded-brand shadow-md"
        />
      )}
    </div>
    <div class="w-full md:w-1/2 space-y-6">
      {data.title && <h2 class="h2-serif text-balance">{data.title}</h2>}
      {data.subtitle && <p class="subtitle-serif opacity-90">{data.subtitle}</p>}
      {data.body && <div class="body-lg opacity-90 prose" set:html={marked.parse(data.body)} />}
      
      {data.link_text && data.link_url && (
        <div class="flex justify-start pt-4">
          <a href={formatUrl(data.link_url)} class="eyebrow inline-flex items-center gap-2 border-b border-current/20 pb-1 transition-all duration-300 hover:border-terracotta hover:text-terracotta group">
            <span>{data.link_text}</span>
            <svg class="w-4 h-4 transform transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      )}
    </div>
  </div>
</Section>
