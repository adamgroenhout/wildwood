---
import Section from '../Section.astro';
import Button from '../Button.astro';
import { formatUrl } from '../../utils/paths';
import { marked } from 'marked';

interface Props {
  data: {
    title?: string;
    subtitle?: string;
    items: Array<{
      title?: string;
      subtitle?: string;
      text?: string;
      body?: string;
      number?: string;
      link_url?: string;
      link_text?: string;
    }>;
    button_text?: string;
    button_url?: string;
    theme?: 'sage' | 'cream' | 'sand' | 'paper' | 'charcoal' | 'olive' | 'alternate';
    columns?: '2' | '3' | '4';
    alignment?: 'left' | 'center';
    style?: 'cards' | 'minimal' | 'numbered';
    padding?: 'standard' | 'large' | 'small' | 'top-only' | 'bottom-only' | 'x-only' | 'none';
  }
}

const { data } = Astro.props;

const gridCols = {
  '2': 'md:grid-cols-2',
  '3': 'md:grid-cols-3',
  '4': 'md:grid-cols-2 lg:grid-cols-4',
};

const colClass = gridCols[data.columns || '3'];
const isDark = ['charcoal', 'olive', 'terracotta'].includes(data.theme || '');
const alignment = data.alignment || 'center';
const isCentered = alignment === 'center';
---

<Section theme={data.theme || 'alternate'} padding={data.padding || 'standard'} class={isDark ? 'theme-dark' : ''}>
  <div class="max-w-6xl mx-auto space-y-16">
    
    {(data.title || data.subtitle) && (
      <div class:list={["space-y-4 mx-auto", isCentered ? 'text-center max-w-3xl' : 'text-left']}>
        {data.subtitle && (
          <p class="eyebrow text-terracotta text-pretty">
            {data.subtitle}
          </p>
        )}
        {data.title && (
          <h2 class:list={["display-serif italic lowercase tracking-tight whitespace-pre-wrap text-pretty", isCentered ? 'text-center' : 'text-left']}>
            {data.title.split('\n').map((line, i) => (
              <>
                {i > 0 && <br />}
                {line}
              </>
            ))}
          </h2>
        )}
        {data.title && !data.subtitle && <div class:list={["w-24 h-px bg-terracotta/30 mt-8", isCentered ? 'mx-auto' : '']}></div>}
      </div>
    )}
    
    <div class:list={[
      "grid gap-x-10 gap-y-16 lg:gap-x-16 lg:gap-y-20",
      data.items.length === 1 ? (isCentered ? "max-w-3xl mx-auto" : "max-w-3xl") : colClass,
      'text-left'
    ]}>
      {data.items.map((item) => (
        <div class:list={[
          "space-y-8 transition-[transform,box-shadow] duration-500 flex flex-col h-full",
          data.style === 'cards' ? "bg-paper p-8 md:p-10 rounded-brand shadow-soft hover:shadow-elevated hover:-translate-y-1 border border-black/5" : ""
        ]}>
          {data.style === 'numbered' && item.number && (
            <span class="display-serif opacity-20 block mb-2 text-6xl text-terracotta">{item.number}</span>
          )}
          <div class="space-y-4 flex-grow">
            {item.title && <h3 class="eyebrow text-terracotta tracking-wider text-pretty">{item.title}</h3>}
            {item.subtitle && <p class="h3-serif !italic leading-snug text-pretty">{item.subtitle}</p>}
            {(item.text || item.body) && <div class="body-lg opacity-85 leading-relaxed prose prose-sm max-w-none text-pretty" set:html={marked.parse((item.text || item.body) as string)} />}
          </div>
          {item.link_url && (
            <div class="pt-4 mt-auto">
              <a href={formatUrl(item.link_url)} class="eyebrow inline-flex items-center gap-2 border-b border-current/20 pb-1 transition-all duration-300 hover:border-terracotta hover:text-terracotta group">
                <span>{item.link_text || 'Learn more'}</span>
                <svg class="w-4 h-4 transform transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          )}
        </div>
      ))}
    </div>

    {data.button_text && data.button_url && (
      <div class="pt-12 text-center">
        <Button href={data.button_url} theme={isDark ? 'white' : 'terracotta'}>
          {data.button_text}
        </Button>
      </div>
    )}

  </div>
</Section>
