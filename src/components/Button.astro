---
import { formatUrl } from '../utils/paths';

interface Props {
  href: string;
  theme?: 'terracotta' | 'outline' | 'white' | 'olive-outline';
  class?: string;
  [key: string]: any;
}

const { 
  href, 
  theme = 'terracotta', 
  class: className = '', 
  ...rest 
} = Astro.props;

const themeClasses = {
  terracotta: 'btn-terracotta',
  outline: 'btn-outline',
  white: 'btn-white',
  'olive-outline': 'btn-outline',
};

const baseClasses = 'btn';
---

<a 
  href={formatUrl(href)} 
  class:list={[baseClasses, themeClasses[theme], className]}
  {...rest}
>
  <slot />
</a>
