---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import { formatUrl } from '../utils/paths';

const telehealthEntry = await getEntry('pages', 'telehealth');
const { title, subtitle, why_telehealth, what_to_expect, bottom_text, cta_text, cta_url } = telehealthEntry?.data || {};
---

<Layout title="Telehealth | Wildwood Psychotherapy">
	<main>
		<Section theme="alternate" padding="hero" class="pb-20 px-4">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="display-serif mb-16 text-center">{title}</h1>
				<p class="subtitle-serif text-center mb-12">{subtitle}</p>
			</div>
		</Section>

		<Section theme="alternate">
			<div class="max-w-4xl mx-auto">
				<div class="prose prose-invert body-lg max-w-none space-y-20">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start border-b border-white/10 pb-20">
						<div class="space-y-8">
							<h2 class="h1-serif">{why_telehealth?.title}</h2>
							<div class="space-y-6">
								{why_telehealth?.items?.map((item: any) => (
									<div class="flex gap-4">
										<span class="text-terracotta font-serif">•</span>
										<div class="space-y-1">
											<p class="font-bold text-sm uppercase tracking-wider opacity-60">{item.label}</p>
											<p class="text-base opacity-90">{item.text}</p>
										</div>
									</div>
								))}
							</div>
						</div>
						<div class="bg-white/5 p-8 border border-white/10 rounded-lg space-y-8">
							<h2 class="h1-serif">{what_to_expect?.title}</h2>
							<div class="space-y-6">
								{what_to_expect?.steps?.map((step: any, i: number) => (
									<div class="flex gap-4">
										<span class="font-serif italic text-terracotta/40">0{i + 1}</span>
										<div class="space-y-1">
											<p class="font-bold text-sm uppercase tracking-wider opacity-60">{step.label}</p>
											<p class="text-base opacity-90">{step.text}</p>
										</div>
									</div>
								))}
							</div>
						</div>
					</div>

					<div class="text-center space-y-10">
						<p class="subtitle-serif italic text-2xl max-w-2xl mx-auto">{bottom_text}</p>
						
						<div class="pt-4">
							<Button href={cta_url} theme="terracotta">
								{cta_text}
							</Button>
						</div>
					</div>
				</div>
			</div>
		</Section>
	</main>
</Layout>
