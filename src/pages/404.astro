---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
---

<Layout title="Page Not Found">
	<main>
		<Section theme="alternate" padding="hero" class="text-center min-h-[70vh] flex items-center justify-center">
			<div class="max-w-2xl mx-auto reveal">
				<p class="eyebrow mb-6">Error 404</p>
				<h1 class="display-serif mb-8 text-balance">Page not found</h1>
				<p class="subtitle-serif mb-12 text-pretty">
					It seems the page you're looking for has moved or no longer exists. 
					Let's help you find your way back.
				</p>
				<div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
					<Button href="/" theme="terracotta">
						Return Home
					</Button>
					<Button href="/contact" theme="outline">
						Get in Touch
					</Button>
				</div>
			</div>
		</Section>
	</main>
</Layout>
