---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import { formatUrl } from '../utils/paths';

const holdingEntry = await getEntry('pages', 'holding-it-together');
const { title, subtitle, hero_section, who_for_section, program_details, footer_cta } = holdingEntry?.data || {};
---

<Layout title="Holding It Together Group | Wildwood Psychotherapy">
	<main>
		<Section theme="alternate" padding="hero" class="pb-20 px-4">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="display-serif mb-16">{title}</h1>
				<p class="subtitle-serif text-center mb-12">{subtitle}</p>
				
				<div class="prose prose-invert body-lg max-w-none space-y-8">
					<div class="bg-white/5 p-8 border border-white/10 rounded-lg text-center">
						<h2 class="eyebrow mb-6 text-terracotta">{hero_section?.title}</h2>
						<p>{hero_section?.text1}</p>
						<p>{hero_section?.text2}</p>
						<p>{hero_section?.text3}</p>
					</div>
				</div>
			</div>
		</Section>

		<Section theme="alternate">
			<div class="max-w-4xl mx-auto">
				<div class="grid md:grid-cols-2 gap-12 items-start mb-20">
					<div class="space-y-6">
						<h2 class="h1-serif">{who_for_section?.title}</h2>
						<p class="body-lg opacity-80 italic">{who_for_section?.footer_italic}</p>
					</div>
					<div class="bg-white/5 border border-white/10 p-8 shadow-sm rounded-lg">
						<ul class="space-y-3 list-none pl-0">
							{who_for_section?.points?.map((item: string) => (
								<li class="flex gap-3">
									<span class="text-terracotta">•</span>
									<span class="opacity-80">{item}</span>
								</li>
							))}
						</ul>
					</div>
				</div>

				<div class="space-y-12 mb-20">
					<h2 class="h1-serif text-center">{program_details?.title}</h2>
					<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
						{[
							{ label: 'Duration', value: program_details?.duration },
							{ label: 'Location', value: program_details?.location },
							{ label: 'Format', value: program_details?.format },
							{ label: 'Cohort Size', value: program_details?.cohort_size },
							{ label: 'Cost', value: program_details?.cost }
						].filter(item => item.value).map(item => (
							<div class="bg-white/5 p-6 border border-white/5 rounded-lg text-center">
								<p class="eyebrow text-[10px] opacity-60 mb-2">{item.label}</p>
								<p class="text-base font-medium">{item.value}</p>
							</div>
						))}
					</div>

					{program_details?.weekly_focus && (
						<div class="bg-white/5 p-10 border border-white/10 rounded-lg max-w-3xl mx-auto">
							<h3 class="h2-serif mb-8 text-center">{program_details.weekly_focus.title}</h3>
							<div class="grid gap-4">
								{program_details.weekly_focus.weeks.map((week: string, i: number) => (
									<div class="flex gap-6 items-baseline border-b border-white/5 pb-3 last:border-0">
										<span class="font-serif italic text-terracotta opacity-60">Week {i + 1}</span>
										<span class="opacity-90">{week}</span>
									</div>
								))}
							</div>
						</div>
					)}
				</div>

				<div class="text-center space-y-10 border-t border-black/5 pt-20">
					<div class="space-y-4">
						<h2 class="h1-serif italic">{footer_cta?.title}</h2>
						<p class="opacity-80">{footer_cta?.text}</p>
					</div>
					<div class="flex flex-col sm:flex-row justify-center gap-6">
						<Button href={footer_cta?.primary_button?.url} theme="terracotta">
							{footer_cta?.primary_button?.text}
						</Button>
						{footer_cta?.secondary_button && (
							<Button href={footer_cta?.secondary_button?.url} theme="terracotta">
								{footer_cta?.secondary_button?.text}
							</Button>
						)}
					</div>
				</div>
			</div>
		</Section>
	</main>
</Layout>
